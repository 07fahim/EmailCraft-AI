# Core LLM Configuration (Pick ONE provider)
# Option A: Google Gemini (recommended - free tier: 1,500 req/day)
# Get API key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_MODEL=gemini-2.0-flash

# Option B: Groq (fallback - free tier: ~30 req/min, 429-prone)
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.1-8b-instant

# Lead Sourcing (Optional - for automated lead generation)
APIFY_API_KEY=your_apify_api_key_here

# LangSmith Tracing (Optional - for monitoring and debugging)
# Get your API key from: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_your_langsmith_api_key_here
LANGCHAIN_PROJECT=cold-outreach-ai-agent

# Production Configuration (Only for deployment)
# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_ENVIRONMENT=us-east-1
# DATABASE_URL=postgresql://user:password@host:5432/dbname
